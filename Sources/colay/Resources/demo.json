{
  "name": "demo",
  "loop": false,
  "actions": [
    { "type": "log", "message": "colay demo start" },
    { "type": "setBehavior", "mode": "idle" },
    { "type": "wait", "duration": 0.6 },

    { "type": "flyTo", "to": { "x": 260, "y": 220 } },
    { "type": "hop" },
    { "type": "wait", "duration": 0.4 },

    { "type": "flyTo", "to": { "x": 900, "y": 600 } },
    { "type": "parallel", "actions": [
        { "type": "highlightFocusedWindow", "duration": 1.6 },
        { "type": "captureFocusedWindow" }
    ]},

    { "type": "followCursor", "duration": 4.0, "orbitRadius": 120 },

    { "type": "scaleTo", "scale": 1.3, "duration": 0.35, "easing": "easeOutBack" },
    { "type": "wait", "duration": 0.3 },
    { "type": "scaleTo", "scale": 1.0, "duration": 0.35, "easing": "easeInOut" },

    { "type": "fadeTo", "alpha": 0.35, "duration": 0.4 },
    { "type": "wait", "duration": 0.3 },
    { "type": "fadeTo", "alpha": 1.0, "duration": 0.4 }
  ]
}
